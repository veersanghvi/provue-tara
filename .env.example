# ---- Database (required) ----
# Neon / Supabase / Render / local Postgres connection string.
# Neon example: postgres://USER:PASSWORD@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/provue_tara

# ---- LLM provider (required to run the agent / server / evals) ----
# Which provider Tara uses. One of: anthropic | openai
MODEL_PROVIDER=anthropic

# Set the key that matches MODEL_PROVIDER. Leave the other blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: override the default model id for the chosen provider.
# anthropic default: claude-3-5-sonnet-latest   openai default: gpt-4o
# MODEL_ID=claude-3-5-sonnet-latest

# ---- Server ----
PORT=3000

# ---- Ingest ----
# Snapshot folder to load. Overridden per-run: DATA_DIR=./data/sample_b npm run ingest
DATA_DIR=./data/sample_a
